# Telegram 配置模板 — 复制为 telegram.local.yaml 或改用 GitHub Secrets（推荐）
# 优先级：workflow secrets > 环境变量 TG_BOT_TOKEN/TG_CHAT_ID > 本文件
# 切勿将含真实 Token 的文件提交到 Git

enabled: true

# 留空则从 Secrets / 环境变量读取（企业推荐）
bot_token: ""
chat_id: ""
bot_username: "@your_bot"

send_summary_message: true
send_test_cases_md: true
send_bug_report_md: true
send_audit_logs: true
send_requirements_checklist: true
max_log_size_kb: 5000
